# IRIN Gateway runtime configuration.
# setup-local.sh replaces generated credential markers on first install.

AUTH_PEPPER=__GENERATED_AUTH_PEPPER__
BOOTSTRAP_TOKEN=__GENERATED_BOOTSTRAP_TOKEN__
WATCH_ADMIN_TOKEN=__GENERATED_WATCH_ADMIN_TOKEN__
COUNCIL_GATEWAY_TOKEN=__GENERATED_COUNCIL_GATEWAY_TOKEN__
COUNCIL_GATEWAY_KEY_ID=
CLAUDE_PROXY_TOKEN=__GENERATED_CLAUDE_PROXY_TOKEN__
CODEX_PROXY_TOKEN=__GENERATED_CODEX_PROXY_TOKEN__

GATEWAY_DURABLE=1
GATEWAY_AUTH_FAIL_CLOSED=true
SIDECAR_SOCKET_MODE=0660
SIDECAR_SOCKET_GID=9999

GW_ENABLE_COUNCIL_ENDPOINT=1
COUNCIL_BASE_URL=http://host.docker.internal:8765

WATCH_DISPATCHER_ENABLED=false
WATCH_PRODUCER_ENABLED=false
WATCH_CANARY_TENANT=canary
DAILY_SPEND_CAP_USD=25
WATCH_MAX_FANOUT_COST_USD=2.50

RECON_CADENCE_SECS=
RECON_DIVERGENCE_THRESHOLD_USD=
RECON_IMPORT_PATH=/var/lib/sidecar/recon/provider-export.json
RECON_AUTO_DISARM=
ROOT_PUBKEY_HEX=

GW_ARM_PRINCIPALS=
GW_ARM_DEVIATION_FLAG=
GW_ARM_PRINCIPAL_DOMAINS=
ARM_NOTIFY_URL=
ARM_STAGE_TTL_MS=

WATCH_DISPATCHER_GATEWAY_KEY=
COUNCIL_AUTH_TOKEN=
