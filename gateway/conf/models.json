{
  "_source": "Model registry; verify identifiers and pricing against provider documentation before changing defaults.",

  "providers": {
    "xai": {
      "base_url": "https://api.x.ai",
      "api_key_env": "XAI_API_KEY",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "openai"
    },
    "openai": {
      "base_url": "https://api.openai.com",
      "api_key_env": "OPENAI_API_KEY",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "openai"
    },
    "gpt-cli": {
      "base_url_env": "CODEX_PROXY_URL",
      "base_url": "http://192.168.65.254:9091",
      "api_key_env": "_GPT_CLI_DUMMY",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "openai",
      "_comment": "Host-side codex-proxy.py — uses Codex CLI (ChatGPT Pro/Plus OAuth, no API key). Mirrors claude-cli. Set CODEX_PROXY_URL env to override base_url."
    },
    "anthropic": {
      "base_url": "https://api.anthropic.com",
      "api_key_env": "ANTHROPIC_API_KEY",
      "auth_header": "x-api-key",
      "auth_prefix": "",
      "format": "anthropic",
      "extra_headers": {
        "anthropic-version": "2023-06-01"
      }
    },
    "claude-cli": {
      "base_url_env": "CLAUDE_PROXY_URL",
      "base_url": "http://192.168.65.254:9090",
      "api_key_env": "_CLAUDE_CLI_DUMMY",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "openai",
      "_comment": "Host-side claude-proxy.py — uses Claude CLI pipe mode (Max/ProMax sub, no API key). Set CLAUDE_PROXY_URL env to override base_url."
    },
    "vertex": {
      "base_url": "https://aiplatform.googleapis.com",
      "api_key_env": "VERTEX_ADC_TOKEN",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "vertex",
      "_comment": "Vertex route using ADC/global by default; the Rust sidecar refreshes ADC tokens when VERTEX_ADC_TOKEN is not set."
    },
    "gemini-cli": {
      "base_url_env": "GEMINI_PROXY_URL",
      "base_url": "http://192.168.65.254:9092",
      "api_key_env": "_GEMINI_CLI_DUMMY",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "openai",
      "_comment": "Legacy/scout host-side Gemini proxy. Not an active default because Gemini CLI is retiring toward Antigravity terminal (`agy`) and this path lacks provider usage parsing."
    },
    "nvidia": {
      "base_url": "https://integrate.api.nvidia.com",
      "api_key_env": "NVIDIA_API_KEY",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "openai"
    },
    "chaos": {
      "_comment": "Test-only provider for chaos tests. Points at mock_sse_server.py on the host.",
      "base_url": "http://192.168.65.254:9999",
      "api_key_env": "_CHAOS_DUMMY",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "openai"
    },
    "local": {
      "_comment": "Sovereign fallback for X-Sensitivity-Level: RED. Default points at Ollama on host. Override with LOCAL_LLM_URL to use a different local server (MLX, llama.cpp, vLLM, etc.). The provider is REQUIRED — sidecar-rs panics at startup if no provider=local model is declared, because RED routing has no place to send requests otherwise.",
      "base_url_env": "LOCAL_LLM_URL",
      "base_url": "http://192.168.65.254:11434",
      "api_key_env": "_LOCAL_LLM_DUMMY",
      "auth_header": "Authorization",
      "auth_prefix": "Bearer ",
      "format": "openai"
    },
    "council": {
      "_comment": "Council deliberation exposed as an OpenAI-compatible synchronous model. Uses a custom service-identity header (X-Gateway-Auth), distinct from the per-user bearer. host.docker.internal:8765 is the Council HTTP API on the host. Gated by GW_ENABLE_COUNCIL_ENDPOINT=1.",
      "base_url_env": "COUNCIL_BASE_URL",
      "base_url": "http://host.docker.internal:8765",
      "api_key_env": "COUNCIL_GATEWAY_TOKEN",
      "auth_header": "X-Gateway-Auth",
      "auth_prefix": "",
      "format": "council"
    }
  },

