# API Keys — set these from your provider dashboards.
# Only configure the providers you plan to use.

XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=

# Vertex AI (Gemini) — requires gcloud ADC setup
VERTEX_PROJECT=your-gcp-project
VERTEX_LOCATION=global
VERTEX_GEMINI_MODEL=gemini-3.1-pro-preview
AUTH_PEPPER=
BOOTSTRAP_TOKEN=
GATEWAY_AUTH_FAIL_CLOSED=true

# Management UDS lockdown (Sovereign directive — Block 1, ruling P0-A).
# Socket mode (octal). Default 0660 = owner+group rw, world none (tightened
# from 0777). Invalid value FAILS CLOSED (sidecar refuses to start).
SIDECAR_SOCKET_MODE=0660
# Group gid to chown the socket to so the nginx worker can connect. MUST equal
# the worker's EFFECTIVE gid — which is triad_mgmt (9999), because nginx.conf
# runs `user nobody triad_mgmt` (nginx setgid's to that named group). Using
# nobody's primary 65534 here locks the worker out (502, EACCES). This 9999 must
# stay in sync with both Dockerfiles, the compose default, and nginx.conf.
# Empty/unset = no chown (host same-uid mode). Container mode: keep 9999.
# FOOTGUN: an EXISTING .env that already sets 65534 keeps breaking — the compose
# `:-9999` default only applies when the var is absent. Set this to 9999.
SIDECAR_SOCKET_GID=9999

# p0c/P0-1 — UTC calendar-day council spend cap (USD). Unset → $50 ceiling.
# Env may only LOWER the ceiling (fail-closed: garbage or >50 refuses startup).
# Canary ratification (Council cap b): set to 25 for the capped canary window.
DAILY_SPEND_CAP_USD=25

# p0d-telemetry — out-of-band spend reconciliation (default OFF).
# The recon loop spawns ONLY when RECON_CADENCE_SECS is set AND a source is
# configured. RECON_IMPORT_PATH (operator-dropped provider billing export,
# JSON map / {"day_bucket","total_usd"} / CSV "day,usd") is the robust
# default source; without it, an OPENAI_ADMIN_KEY/OPENAI_API_KEY enables the
# best-effort OpenAI Costs API source. Divergence beyond the threshold writes
# a recon_alarm row and bumps recon_divergence_total on /watch/stats.
RECON_CADENCE_SECS=
RECON_DIVERGENCE_THRESHOLD_USD=
RECON_IMPORT_PATH=
# Org/admin-scoped key for the OpenAI Costs API (best-effort recon source).
OPENAI_ADMIN_KEY=

# --- Tenant / multi-tenant example configs (Phase 3) ---
# Budget keys isolate spend ledgers per tenant/team/project (see ledger + budget in sidecar).
# Provision via: BOOTSTRAP_TOKEN=xxx make provision-key BUDGET=tenant_name TIER=standard RPM=120
# See docs/runbook.md §3 and conf/auth_keys.json.example for full key_hash + rate config.
# DAILY_SPEND_CAP_USD (above) is the council-wide ceiling; per-budget tracked separately.
#
# Common tenant budgets in this triad:
#   dev, team_a, ci, root (admin only)
#
# After bootstrap (first admin key), use the returned admin_key (not BOOTSTRAP) for further provisions.
# Council integration (gateway <-> council-rs auth):
#   COUNCIL_GATEWAY_TOKEN=your-strong-shared-secret-here
#   COUNCIL_BASE_URL=http://127.0.0.1:8765
#   (Also configure matching token on council side when using signed calls.)
#
# Optional warroom: council --serve (started by install.sh) provides War Room backend + /ws/deliberate.
# Full desktop War Room: see sibling council-warroom-tauri-experiment.
#
# Post-install verification (cross-ref triad-doctor skill):
#   hermes doctor
#   # or explicitly: hermes --skills triad-doctor doctor   (health for gateway:18080 + council:8765 + warroom + hermes maint)
# See also: make smoke after provisioning a key.

# Council gateway token (for council-triage / Phase 3 dispatcher auth from sidecar -> gateway)
# Provision a dedicated key via make provision-key then set the raw value here.
# WATCH_DISPATCHER_GATEWAY_KEY=gw_live_...
