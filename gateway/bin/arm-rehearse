#!/bin/sh
# Rehearsal suite driver (spec §8, B7/B8). Walks the operator through the
# §8 dry-run table against the LIVE sidecar using rehearsal-mode stages —
# every path is the real path (real stage, real Touch ID, real verify, real
# audit rows) except arm_producer_start, which rehearsal NEVER calls.
#
# B8 pass bar: every case below PASS, three consecutive clean happy-path
# ceremonies, zero errors. Results land in arm_audit (stage_rehearsal /
# confirm_rehearsal rows) — that chain IS the sign-off record.
#
# Cases:
#   1 happy-path     bin/arm --rehearse end-to-end -> rehearsal-ok
#   2 timeout        stage, let the window lapse, confirm -> 410 challenge_expired
#   3 crash-resume   stage, kill the script, re-run -> SAME stage_id resumed
#   4 wrong-stage-id confirm against a wrong well-formed stage_id -> 409
#   5 fake-deny      cancel the Touch ID prompt -> helper fails, nothing confirms
#   6 rate-limit     4th sign attempt inside 300s window -> exit 75, no prompt
#   7 bio-invalidate (operator, destructive to the SE key — separate consent)
set -eu
cd "$(dirname "$0")/.."

. bin/lib/runtime-env.sh
TOK=$(irin_arm_principal_token) || exit 1
SIDECAR_SOCKET_VOLUME=$(irin_sidecar_socket_volume)
HELPER=bin/arm-attest

PASS=0
FAIL=0
note()   { printf '\n=== case %s ===\n' "$1"; }
result() { # result <case> <PASS|FAIL> <detail>
  printf '[%s] case %s: %s\n' "$2" "$1" "$3"
  if [ "$2" = "PASS" ]; then PASS=$((PASS + 1)); else FAIL=$((FAIL + 1)); fi
}

curl_uds() {
  docker run --rm -i --user 0 -v "$SIDECAR_SOCKET_VOLUME":/run/sidecar \
    curlimages/curl:8.12.1 -s --unix-socket /run/sidecar/sidecar.sock "$@"
}

stage_rehearsal() {
  curl_uds -X POST http://localhost/watch/admin/producer/arm/stage \
    -H "Authorization: Bearer sovereign-op:$TOK" \
    -H "Content-Type: application/json" -d '{"rehearse": true}'
}

clear_pending() { # best-effort: wait out / disarm any leftover stage
  curl_uds -X POST http://localhost/watch/admin/producer/disarm \
    -H "Authorization: Bearer sovereign-op:$TOK" >/dev/null 2>&1 || true
}

# --- case 1: happy path (x3 consecutive = B8 pass bar) ---------------------
note "1 happy-path (3 consecutive clean ceremonies)"
N=0
while [ $N -lt 3 ]; do
  N=$((N + 1))
  echo "--- ceremony $N/3: touch the sensor when prompted ---"
  if OUT=$(bin/arm --rehearse) && printf '%s' "$OUT" | grep -q "rehearsal-ok"; then
    result "1.$N" PASS "rehearsal-ok"
  else
    result "1.$N" FAIL "expected rehearsal-ok, got: $OUT"
  fi
  # respect helper rate limit: 3 attempts / 300s — case 6 needs the 4th to
  # be the refused one, so pause between ceremonies only if continuing
done
echo "NOTE: helper rate-limit window now has 3 attempts spent — case 6 runs NEXT on purpose."

# --- case 6: rate limit (mechanical, no Touch ID prompt should appear) ----
note "6 rate-limit (4th attempt in window must refuse, exit 75)"
S=$(stage_rehearsal)
SID=$(printf '%s' "$S" | jq -r '.stage_id // empty')
CH=$(printf '%s' "$S" | jq -r '.challenge // empty')
if [ -z "$SID" ]; then
  result 6 FAIL "rehearsal stage failed: $S"
else
  set +e
  "$HELPER" sign --challenge "$CH" --stage-id "$SID" >/dev/null 2>&1
  RC=$?
  set -e
  if [ "$RC" = "75" ]; then
    result 6 PASS "4th sign attempt refused mechanically (exit 75), no prompt fired"
  else
    result 6 FAIL "expected exit 75, got exit $RC"
  fi
  echo "leaving stage $SID open for case 3 (crash-resume)..."
fi

# --- case 3: crash-resume (reuse the stage case 6 left open) ---------------
note "3 crash-resume (open stage must be RESUMED, same stage_id)"
P=$(curl_uds http://localhost/watch/admin/producer/arm/pending \
  -H "Authorization: Bearer sovereign-op:$TOK")
RSID=$(printf '%s' "$P" | jq -r '.stage_id // empty')
if [ -n "$SID" ] && [ "$RSID" = "$SID" ]; then
  result 3 PASS "pending GET returned the same stage_id ($SID) — resume path intact"
else
  result 3 FAIL "expected stage_id $SID, pending returned: $P"
fi

# --- case 4: wrong-stage-id (well-formed mismatch -> 409) -------------------
note "4 wrong-stage-id (well-formed wrong id must 409, stage must survive)"
WRONG="deadbeefdeadbeefdeadbeefdeadbeef"
RC4=$(curl_uds -o /dev/null -w '%{http_code}' \
  -X POST http://localhost/watch/admin/producer/arm/confirm \
  -H "Authorization: Bearer sovereign-op:$TOK" \
  -H "Content-Type: application/json" \
  -d "{\"stage_id\":\"$WRONG\",\"credential_id\":\"none\",\"credential_type\":\"se-p256\",\"signature\":\"AA==\"}")
P2=$(curl_uds http://localhost/watch/admin/producer/arm/pending \
  -H "Authorization: Bearer sovereign-op:$TOK" | jq -r '.stage_id // empty')
if [ "$RC4" = "409" ] && [ "$P2" = "$SID" ]; then
  result 4 PASS "409 on mismatch, original stage survived"
else
  result 4 FAIL "expected 409 + surviving stage, got HTTP $RC4, pending=$P2"
fi

# --- case 2: timeout (wait out the window, then confirm -> 410) -------------
note "2 timeout (waiting out the stage window — this takes the full TTL)"
LEFT=$(curl_uds http://localhost/watch/admin/producer/arm/pending \
  -H "Authorization: Bearer sovereign-op:$TOK" | jq -r '.expires_in_ms // 0')
echo "sleeping $(( LEFT / 1000 + 2 ))s for the stage window to lapse..."
sleep $(( LEFT / 1000 + 2 ))
RC2=$(curl_uds -o /dev/null -w '%{http_code}' \
  -X POST http://localhost/watch/admin/producer/arm/confirm \
  -H "Authorization: Bearer sovereign-op:$TOK" \
  -H "Content-Type: application/json" \
  -d "{\"stage_id\":\"$SID\",\"credential_id\":\"none\",\"credential_type\":\"se-p256\",\"signature\":\"AA==\"}")
if [ "$RC2" = "410" ]; then
  result 2 PASS "expired stage confirm returned 410 (row cleared in-tx)"
else
  result 2 FAIL "expected 410, got HTTP $RC2"
fi

# --- case 5: fake-deny (operator cancels the Touch ID prompt) ---------------
# Earlier cases spent helper rate-limit tokens. Rather than a blind sleep
# (hardening: a concurrent ceremony could leave the bucket full and FAIL
# this case spuriously), retry the sign until the bucket frees — exit 75 is
# the rate-limit signal, anything else is the real (cancelable) prompt.
note "5 fake-deny (CANCEL the next Touch ID prompt — press Esc / Cancel)"
S5=$(stage_rehearsal)
SID5=$(printf '%s' "$S5" | jq -r '.stage_id // empty')
CH5=$(printf '%s' "$S5" | jq -r '.challenge // empty')
if [ -z "$SID5" ]; then
  result 5 FAIL "rehearsal stage failed: $S5"
else
  echo ">>> when the prompt appears, CANCEL it — do NOT touch the sensor <<<"
  RC5=75
  TRIES=0
  while [ "$RC5" = "75" ] && [ "$TRIES" -lt 12 ]; do
    TRIES=$((TRIES + 1))
    set +e
    "$HELPER" sign --challenge "$CH5" --stage-id "$SID5" >/dev/null 2>&1
    RC5=$?
    set -e
    [ "$RC5" = "75" ] && { echo "  rate-limit bucket full; waiting 30s for a free slot..."; sleep 30; }
  done
  if [ "$RC5" = "75" ]; then
    result 5 FAIL "bucket never freed after $TRIES tries — rerun case 5 alone"
  elif [ "$RC5" != "0" ]; then
    result 5 PASS "canceled prompt failed the helper (exit $RC5); nothing reached confirm"
  else
    result 5 FAIL "helper exited 0 — did you touch the sensor? rerun case 5"
  fi
fi

# --- case 7: biometric invalidation (manual, destructive) -------------------
note "7 biometric-invalidation (MANUAL — destroys the SE key binding)"
cat <<'EOF'
Case 7 invalidates the SE key on purpose (.biometryCurrentSet):
  a. System Settings -> Touch ID -> add OR remove a fingerprint
  b. run: bin/arm --rehearse
  c. EXPECT: helper fails with "key blob load failed (enclave/biometry
     change invalidates the key ...)" — the old key must be unusable
  d. recover: archive ~/.config/gateway/arm-attest.key, re-run
     bin/arm-enroll, restart sidecar, verify new keyset hash
Not automated — it changes machine biometry state. Run when ready (B8).
EOF

printf '\n=== rehearsal summary: %d PASS / %d FAIL (case 7 manual) ===\n' "$PASS" "$FAIL"
[ "$FAIL" = "0" ]
