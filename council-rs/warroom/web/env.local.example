# Copy to .env.local
# Backend URL (Rust axum server)
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8765
NEXT_PUBLIC_WS_BASE=ws://127.0.0.1:8765
# Optional direct Gateway health probe; Watch and Outbox use the Council BFF
NEXT_PUBLIC_GATEWAY_BASE=http://127.0.0.1:18080
# Optional: match COUNCIL_AUTH_TOKEN on council --serve (or use Settings at runtime)
# NEXT_PUBLIC_COUNCIL_AUTH_TOKEN=
