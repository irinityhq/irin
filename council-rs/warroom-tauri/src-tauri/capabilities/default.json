{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "dialog:default",
    "dialog:allow-open",
    "notification:default",
    "notification:allow-request-permission",
    "notification:allow-notify"
  ]
}
